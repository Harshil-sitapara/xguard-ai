# ─── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_USER=xguard
POSTGRES_PASSWORD=xguard_secret
POSTGRES_DB=xguard
DATABASE_URL=

# ─── Kafka ─────────────────────────────────────────────────────────────────
# Local Docker: kafka:29092  |  Confluent Cloud: your-cluster.confluent.cloud:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_TRAFFIC=network-traffic
KAFKA_TOPIC_ALERTS=ids-alerts
KAFKA_GROUP_ID=xguard-consumer

# ─── API Security ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
API_SECRET_KEY=CHANGE_ME
# Public key for frontend (limited permissions): predict + alerts
API_PUBLIC_KEY=CHANGE_ME_PUBLIC

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PREDICT=30/minute
RATE_LIMIT_EXPLAIN=20/minute
RATE_LIMIT_ALERTS=50/minute
RATE_LIMIT_DEFAULT=100/minute

# ─── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Model ──────────────────────────────────────────────────────────────────
BEST_MODEL_TYPE=xgboost
MODELS_DIR=/app/models

# ─── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Frontend Analytics (Firebase Web) ──────────────────────────────────────
# Master analytics switch (set to false to disable analytics everywhere)
NEXT_PUBLIC_ANALYTICS_ENABLED=true
# Disable analytics while running locally/in development by default
NEXT_PUBLIC_DISABLE_ANALYTICS_IN_DEVELOPMENT=true
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
